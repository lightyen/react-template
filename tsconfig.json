{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "dom.iterable", "webworker"],
    "types": ["vite/types/importMeta.d.ts", "rolldown-plugin-twobj/types/emotion.d.ts"],
    "jsx": "preserve",
    "noImplicitAny": false,
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "~/*": ["./src/*"],
      "@context": ["./src/context"],
      "@context/*": ["./src/context/*"],
      "@concepts/*": ["./src/concepts/*"],
      "shadcn/*": ["./shadcn/*"]
    }
  },
  "include": ["*.ts", "./vite-plugins/**/*", "./src/**/*", "./tests/**/*", "./tests-examples/**/*"]
}
